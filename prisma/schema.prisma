// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

// ==================== USER MANAGEMENT ====================

enum UserRole {
  ADMIN
  CUSTOMER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING_VERIFICATION
  DELETED
}

model User {
  id                String      @id @default(cuid())
  email             String      @unique
  emailVerified     DateTime?
  name              String?
  passwordHash      String
  phone             String?
  phoneVerified     DateTime?
  avatar            String?
  role              UserRole    @default(CUSTOMER)
  status            UserStatus  @default(PENDING_VERIFICATION)
  
  // Two-Factor Authentication
  twoFactorEnabled  Boolean     @default(false)
  twoFactorSecret   String?
  twoFactorBackupCodes String?  // JSON array of backup codes
  
  // Security
  lastLoginAt       DateTime?
  lastLoginIp       String?
  failedLoginAttempts Int       @default(0)
  lockedUntil       DateTime?
  
  // Timestamps
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  deletedAt         DateTime?   // Soft delete for GDPR
  
  // Relations
  sessions          Session[]
  auditLogs         AuditLog[]
  gdprConsents      GDPRConsent[]
  dataExportRequests DataExportRequest[]
  
  // Customer specific
  orders            Order[]
  addresses         Address[]
  
  // Notifications
  notifications     Notification[]
  
  @@index([email])
  @@index([role])
  @@index([status])
}

model Session {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token         String   @unique
  userAgent     String?
  ipAddress     String?
  expiresAt     DateTime
  createdAt     DateTime @default(now())
  
  @@index([token])
  @@index([userId])
}

model Address {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName      String
  phone         String?
  country       String
  city          String?
  postalCode    String?
  addressLine1  String
  addressLine2  String?
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([userId])
}

// ==================== PRODUCTS (MobiMatter Sync) ====================

model Product {
  id                    String   @id @default(cuid())
  mobimatterId          String   @unique  // MobiMatter product ID
  
  // Product Info
  name                  String
  description           String?
  provider              String
  category              String?  // data, voice, combo

  // Carrier Truth Layer
  networks              String?  // JSON array of local carriers and their tech (5G/4G)
  bestFitReason         String?  // AI-generated or rule-based fit reason
  
  // Advanced MobiMatter Meta
  activationPolicy      String?  // e.g., "First use", "At purchase"
  topUpAvailable        Boolean  @default(false)
  requiresKyc           Boolean  @default(false)
  providerLogo          String?  // URL to provider logo
  networkType           String?  // e.g., "5G", "4G/LTE", "3G"
  speedInfo             String?  // e.g., "Up to 100 Mbps"
  ipRouting             String?  // e.g., "Local", "International"
  usageTracking         Boolean  @default(false)
  
  // MobiMatter Sorting & Grouping
  rank                  Int?     // Quality factor for sorting (higher = better)
  penalizedRank         Int?     // Adjusted rank for sorting
  productFamilyId       Int?     // Products sharing this can be interchangeably topped up
  networkListId         Int?     // Network list identifier for carrier lookups

  // Quality & Visibility
  tags                  String?  // JSON array of {item, color?} quality badges
  externallyShown       Boolean  @default(true)  // Whether to display to customers
  additionalDetails     String?  // HTML additional info from MobiMatter
  phoneNumberPrefix     String?  // Phone number included with plan (e.g. "+382")
  is5G                  Boolean  @default(false)  // Explicit 5G support flag
  speedLong             String?  // Detailed speed description

  // Coverage
  countries             String?  // JSON array of country codes
  regions               String?  // JSON array of regions
  
  // Data/Validity
  dataAmount            Float?   // In GB
  dataUnit              String?  // GB, MB, Unlimited
  validityDays          Int?
  
  // Pricing
  price                 Float
  currency              String   @default("USD")
  originalPrice         Float?   // MobiMatter retailPrice before markup
  wholesalePrice        Float?   // MobiMatter wholesale cost
  
  // Features
  features              String?  // JSON array of features
  isUnlimited           Boolean  @default(false)
  supportsHotspot       Boolean  @default(true)
  supportsCalls         Boolean  @default(false)
  supportsSms           Boolean  @default(false)
  
  // Status
  isActive              Boolean  @default(true)
  isFeatured            Boolean  @default(false)
  
  // SEO
  slug                  String   @unique
  metaTitle             String?
  metaDescription       String?
  
  // Timestamps
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  syncedAt              DateTime?  // Last sync from MobiMatter
  
  // Relations
  orderItems            OrderItem[]
  
  @@index([mobimatterId])
  @@index([slug])
  @@index([isActive])
  @@index([provider])
}

// ==================== ORDERS ====================

model Order {
  id                    String   @id @default(cuid())
  orderNumber           String   @unique
  
  // Fulfillment Tracking
  notifySent            Boolean  @default(false)
  isTopUp               Boolean  @default(false)
  parentOrderId         String?  // If this is a top-up
  
  // Customer
  userId                String?
  user                  User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  email                 String
  phone                 String?
  
  // Order Details
  status                OrderStatus @default(PENDING)
  subtotal              Float
  discount              Float    @default(0)
  tax                   Float    @default(0)
  total                 Float
  currency              String   @default("USD")
  
  // Payment
  paymentStatus         PaymentStatus @default(PENDING)
  paymentMethod         String?
  paymentReference      String?
  paidAt                DateTime?
  
  // MobiMatter Integration
  mobimatterOrderId     String?
  mobimatterStatus      String?
  esimQrCode            String?
  esimActivationCode    String?
  esimSmdpAddress       String?
  
  // IP Tracking (GDPR)
  ipAddress             String?
  userAgent             String?
  
  // Timestamps
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  completedAt           DateTime?
  
  // Relations
  items                 OrderItem[]
  
  @@index([orderNumber])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

enum OrderStatus {
  PENDING
  PROCESSING
  COMPLETED
  CANCELLED
  REFUNDED
  FAILED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

model OrderItem {
  id                    String   @id @default(cuid())
  orderId               String
  order                 Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId             String
  product               Product  @relation(fields: [productId], references: [id])
  
  // Item Details
  productName           String   // Snapshot at time of order
  quantity              Int      @default(1)
  unitPrice             Float
  totalPrice            Float
  
  // eSIM Details (after activation)
  esimIccid             String?
  esimQrCode            String?
  
  createdAt             DateTime @default(now())
  
  @@index([orderId])
  @@index([productId])
}

// ==================== GDPR COMPLIANCE ====================

model GDPRConsent {
  id                    String   @id @default(cuid())
  userId                String
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Consent Types
  marketingEmails       Boolean  @default(false)
  analytics             Boolean  @default(false)
  thirdPartySharing     Boolean  @default(false)
  
  // Metadata
  ipAddress             String?
  userAgent             String?
  
  // Timestamps
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  @@index([userId])
}

model DataExportRequest {
  id                    String   @id @default(cuid())
  userId                String
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Request Details
  status                ExportStatus @default(PENDING)
  format                String   @default("JSON")  // JSON, CSV
  downloadUrl           String?
  expiresAt             DateTime?
  
  // Timestamps
  createdAt             DateTime @default(now())
  completedAt           DateTime?
  
  @@index([userId])
  @@index([status])
}

enum ExportStatus {
  PENDING
  PROCESSING
  COMPLETED
  EXPIRED
}

model DataDeletionRequest {
  id                    String   @id @default(cuid())
  userId                String
  userEmail             String   // Store email before user is deleted
  
  // Request Details
  status                DeletionStatus @default(PENDING)
  reason                String?
  
  // Timestamps
  createdAt             DateTime @default(now())
  processedAt           DateTime?
  completedAt           DateTime?
  
  @@index([userId])
  @@index([status])
}

enum DeletionStatus {
  PENDING
  PROCESSING
  COMPLETED
  CANCELLED
}

// ==================== SECURITY & AUDIT ====================

model AuditLog {
  id                    String   @id @default(cuid())
  userId                String?
  user                  User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  // Action Details
  action                String   // login, logout, order_create, etc.
  entity                String?  // user, order, product, etc.
  entityId              String?
  
  // Data
  oldValues             String?  // JSON
  newValues             String?  // JSON
  
  // Metadata
  ipAddress             String?
  userAgent             String?
  
  createdAt             DateTime @default(now())
  
  @@index([userId])
  @@index([action])
  @@index([entity, entityId])
  @@index([createdAt])
}

model SecurityEvent {
  id                    String   @id @default(cuid())
  type                  SecurityEventType
  severity              EventSeverity @default(INFO)
  
  // Details
  description           String
  ipAddress             String?
  userAgent             String?
  userId                String?
  email                 String?
  
  // Additional Data
  metadata              String?  // JSON
  
  createdAt             DateTime @default(now())
  
  @@index([type])
  @@index([severity])
  @@index([createdAt])
}

enum SecurityEventType {
  LOGIN_SUCCESS
  LOGIN_FAILED
  LOGOUT
  PASSWORD_CHANGE
  TWO_FACTOR_ENABLED
  TWO_FACTOR_DISABLED
  SUSPICIOUS_ACTIVITY
  RATE_LIMIT_EXCEEDED
  API_KEY_USED
  DATA_EXPORT
  DATA_DELETION
  ACCOUNT_LOCKED
  ACCOUNT_UNLOCKED
}

enum EventSeverity {
  INFO
  WARNING
  ERROR
  CRITICAL
}

// ==================== SYSTEM CONFIGURATION ====================

model SystemConfig {
  id                    String   @id @default(cuid())
  key                   String   @unique
  value                 String   // Encrypted if sensitive
  isEncrypted           Boolean  @default(false)
  description           String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  @@index([key])
}

model APIKey {
  id                    String   @id @default(cuid())
  name                  String
  keyHash               String   @unique  // Hashed API key
  prefix                String   // First 8 chars for identification
  userId                String?
  
  // Permissions
  permissions           String?  // JSON array of permissions
  
  // Status
  isActive              Boolean  @default(true)
  lastUsedAt            DateTime?
  expiresAt             DateTime?
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  @@index([keyHash])
  @@index([prefix])
}

// ==================== NOTIFICATIONS ====================

model Notification {
  id                    String   @id @default(cuid())
  userId                String
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Content
  type                  String   // order, commission, system, etc.
  title                 String
  message               String
  data                  String?  // JSON additional data
  
  // Status
  isRead                Boolean  @default(false)
  readAt                DateTime?
  
  createdAt             DateTime @default(now())
  
  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

// ==================== REVIEWS ====================

model Review {
  id            String   @id @default(cuid())

  // Reviewer
  orderId       String?  // Optional link to order for verification
  userId        String?  // Optional link to user
  name          String
  email         String

  // Review Content
  rating        Int      // 1-5
  title         String
  text          String

  // Context
  destination   String?  // Country or region name
  countryCode   String?  // ISO country code

  // Status
  verified      Boolean  @default(false)  // Verified purchase
  approved      Boolean  @default(false)  // Admin approved

  // Timestamps
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([approved])
  @@index([rating])
  @@index([destination])
  @@index([createdAt])
}

// ==================== RATE LIMITING ====================

model RateLimitLog {
  id                    String   @id @default(cuid())
  identifier            String   // IP or user ID
  endpoint              String
  requestCount          Int      @default(1)
  windowStart           DateTime @default(now())
  blockedAt             DateTime?

  @@index([identifier, endpoint])
  @@index([windowStart])
}

// ==================== MONITORING & ANALYTICS ====================

model ErrorLog {
  id            String        @id @default(cuid())

  // Error classification
  level         ErrorLevel    @default(ERROR)
  source        ErrorSource   @default(SERVER)

  // Error details
  message       String
  stack         String?
  digest        String?       // Next.js error digest for deduplication

  // Request context
  path          String?       // URL path where error occurred
  method        String?       // HTTP method (GET, POST, etc.)
  statusCode    Int?          // HTTP status code if applicable

  // User context
  userId        String?
  ipAddress     String?
  userAgent     String?

  // Additional data
  metadata      String?       // JSON — request body, headers, etc.

  // Deduplication
  fingerprint   String?       // Hash of message + stack for grouping
  occurrences   Int           @default(1)
  lastSeenAt    DateTime      @default(now())

  // Resolution
  resolved      Boolean       @default(false)
  resolvedAt    DateTime?
  resolvedBy    String?

  createdAt     DateTime      @default(now())

  @@index([level])
  @@index([source])
  @@index([fingerprint])
  @@index([resolved])
  @@index([createdAt])
  @@index([path])
}

enum ErrorLevel {
  DEBUG
  INFO
  WARNING
  ERROR
  CRITICAL
}

enum ErrorSource {
  SERVER      // API routes, server components, services
  CLIENT      // Browser-side errors
  MIDDLEWARE  // Middleware errors
  CRON        // Scheduled job errors
  WEBHOOK     // Webhook processing errors
}

model PageView {
  id            String   @id @default(cuid())

  // Page info
  path          String
  referrer      String?

  // Visitor info
  sessionId     String        // Anonymous session identifier
  userId        String?       // If logged in
  ipAddress     String?
  userAgent     String?

  // Device/browser
  device        String?       // mobile, tablet, desktop
  browser       String?       // chrome, safari, firefox, etc.
  os            String?       // windows, macos, ios, android, etc.
  country       String?       // Detected from IP or Accept-Language

  // Performance
  loadTimeMs    Int?          // Page load time in milliseconds

  createdAt     DateTime      @default(now())

  @@index([path])
  @@index([sessionId])
  @@index([userId])
  @@index([createdAt])
  @@index([country])
}

model AnalyticsEvent {
  id            String   @id @default(cuid())

  // Event identification
  name          String        // e.g., product_view, add_to_cart, checkout_start, purchase
  category      String?       // e.g., ecommerce, engagement, navigation

  // Event data
  properties    String?       // JSON — event-specific data (productId, price, etc.)
  value         Float?        // Numeric value (e.g., order total, product price)

  // Visitor info
  sessionId     String
  userId        String?
  ipAddress     String?

  // Context
  path          String?       // Page where event occurred

  createdAt     DateTime      @default(now())

  @@index([name])
  @@index([category])
  @@index([sessionId])
  @@index([userId])
  @@index([createdAt])
  @@index([name, createdAt])
}
